# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Postgres connection string from Supabase (Project Settings > Database > Connection string).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# A long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Anthropic API key for the "what to build next" feature (console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port the API runs on locally.
PORT=4000

# Where the React app runs, so CORS lets it through.
CLIENT_ORIGIN=http://localhost:5173
